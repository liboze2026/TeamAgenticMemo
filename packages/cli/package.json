{
  "name": "@teamagent/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "teamagent": "./src/bin.ts"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsup src/bin.ts --format esm && pnpm build:hook",
    "build:hook": "tsup --config tsup.hook.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@teamagent/adapters": "workspace:*",
    "@teamagent/core": "workspace:*",
    "@teamagent/ports": "workspace:*",
    "@teamagent/types": "workspace:*",
    "cli-table3": "^0.6.5",
    "js-tiktoken": "^1.0.12",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
