{
  "name": "teamagent",
  "version": "0.10.0",
  "description": "自进化 AI 规则引擎 for Claude Code | Self-evolving AI rule engine",
  "keywords": ["claude-code", "ai", "hooks", "rules", "self-evolving"],
  "license": "MIT",
  "type": "module",
  "bin": {
    "teamagent": "./dist/bin.js"
  },
  "files": [
    "dist/",
    "postinstall.mjs"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsup",
    "postinstall": "node postinstall.mjs"
  },
  "peerDependencies": {
    "sqlite-vec": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "sqlite-vec": { "optional": true }
  },
  "dependencies": {
    "tree-sitter-python": "^0.23.0",
    "tree-sitter-typescript": "^0.23.0",
    "web-tree-sitter": "^0.26.0"
  },
  "optionalDependencies": {
    "jsdom": "^25.0.0",
    "rss-parser": "^3.13.0",
    "@mozilla/readability": "^0.6.0",
    "@xenova/transformers": "^2.17.0",
    "onnxruntime-node": "^1.19.0",
    "sharp": "^0.33.0"
  }
}
