{
  "permissions": {
    "allow": [
      "Bash(mkdir -p ~/.claude/skills/teamagent-pitfall ~/.claude/skills/teamagent-stats)",
      "Bash(cp /c/bzli/teamagent/packages/skills/pitfall.md ~/.claude/skills/teamagent-pitfall/SKILL.md)",
      "Bash(cp /c/bzli/teamagent/packages/skills/teamagent-stats.md ~/.claude/skills/teamagent-stats/SKILL.md)",
      "Read(//c/Users/tianhaoxuan/.claude/skills/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|WebFetch",
        "_teamagentTag": "teamagent-pre-tool-use",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/bzli/teamagent/packages/cli/dist/bin-pre-tool-use.cjs",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|WebFetch",
        "_teamagentTag": "teamagent-post-tool-use",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/bzli/teamagent/.worktrees/feat-m2.10/packages/cli/dist/bin-post-tool-use.cjs",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_teamagentTag": "teamagent-user-prompt-submit",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/bzli/teamagent/.worktrees/feat-m2.10/packages/cli/dist/bin-user-prompt-submit.cjs",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "_teamagentTag": "teamagent-stop",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/bzli/teamagent/.worktrees/feat-m2.10/packages/cli/dist/bin-stop.cjs",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
