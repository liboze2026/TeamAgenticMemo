{
  "env": {
    "TEAMAGENT_VISIBILITY": "verbose"
  },
  "permissions": {
    "allow": [
      "Bash(mkdir -p ~/.claude/skills/teamagent-pitfall ~/.claude/skills/teamagent-stats)",
      "Bash(cp packages/skills/pitfall.md ~/.claude/skills/teamagent-pitfall/SKILL.md)",
      "Bash(cp packages/skills/teamagent-stats.md ~/.claude/skills/teamagent-stats/SKILL.md)",
      "Read(~/.claude/skills/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"${CLAUDE_PROJECT_DIR:-$PWD}/scripts/teamagent-statusline.cjs\""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|WebFetch",
        "_teamagentTag": "teamagent-pre-tool-use",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-$PWD}/packages/cli/dist/bin-pre-tool-use.cjs\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|WebFetch",
        "_teamagentTag": "teamagent-post-tool-use",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-$PWD}/packages/cli/dist/bin-post-tool-use.cjs\"",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_teamagentTag": "teamagent-user-prompt-submit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-$PWD}/packages/cli/dist/bin-user-prompt-submit.cjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "_teamagentTag": "teamagent-stop",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-$PWD}/packages/cli/dist/bin-stop.cjs\"",
            "timeout": 300
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "_teamagentTag": "teamagent-session-end",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-$PWD}/packages/cli/dist/bin-session-end.cjs\"",
            "timeout": 300
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "_teamagentTag": "teamagent-pre-compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-$PWD}/packages/cli/dist/bin-pre-compact.cjs\"",
            "timeout": 300
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "_teamagentTag": "teamagent-session-start",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-$PWD}/packages/cli/dist/bin-session-start.cjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
