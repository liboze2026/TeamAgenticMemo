{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "canary-skill-frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "preamble_tier",
    "allowed_tools",
    "triggers"
  ],
  "properties": {
    "name":          { "type": "string" },
    "version":       { "type": "string" },
    "preamble_tier": { "type": "integer" },
    "allowed_tools": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "triggers": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  }
}
